# ==========================================
# MERN STACK MASTER GITIGNORE
# ==========================================

# --- Dependencies ---
# This ignores node_modules in root, /client, and /server
node_modules/
/client/node_modules/
/server/node_modules/

# --- Environment Secrets (CRITICAL) ---
# Never upload these! 
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# --- Build Outputs ---
# Production folders for React/Vite
dist/
dist-ssr/
build/
out/

# --- Logs ---
# Error logs from npm, yarn, and pnpm
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Testing ---
# Coverage reports from Vitest or Jest
coverage/
__snapshots__/

# --- Editor & OS Files ---
# VS Code settings
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Database / Temp ---
# If you run a local MongoDB instance
dump/
data/